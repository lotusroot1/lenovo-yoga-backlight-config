#!/usr/bin/env bash
# Keyboard backlight control for Lenovo Yoga 9i Gen 7
# States: off=0, dim=1, on=2
# Note: "auto" (EC-managed inactivity dimming) is only reachable via Fn+Space;
# it reads as 0 at the sysfs level when the keyboard is idle.

BRIGHTNESS=/sys/class/leds/platform::kbd_backlight/brightness

die() { echo "kbd-backlight: $*" >&2; exit 1; }

get() {
    [ -r "$BRIGHTNESS" ] || die "cannot read $BRIGHTNESS"
    local val
    val=$(cat "$BRIGHTNESS")
    case $val in
        0) echo "off" ;;
        1) echo "dim" ;;
        2) echo "on"  ;;
        *) echo "unknown ($val)" ;;
    esac
}

set_state() {
    [ -w "$BRIGHTNESS" ] || die "cannot write $BRIGHTNESS (not in 'input' group, or udev rule not installed?)"
    local val
    case $1 in
        off|0) val=0 ;;
        dim|1) val=1 ;;
        on|2)  val=2 ;;
        *) die "unknown state '$1' — use: off, dim, on  (or 0, 1, 2)" ;;
    esac
    echo "$val" > "$BRIGHTNESS"
}

usage() {
    cat <<EOF
Usage: kbd-backlight <command> [state]

Commands:
  get          print current state (off|dim|on)
  set <state>  set state: off, dim, on  (or 0, 1, 2)
  toggle       cycle off → dim → on → off

Note: the firmware "auto" mode (dims after inactivity) is only reachable
via Fn+Space and cannot be set programmatically.
EOF
}

toggle() {
    local val
    val=$(cat "$BRIGHTNESS")
    set_state $(( (val + 1) % 3 ))
}

case ${1:-} in
    get)    get ;;
    set)    [ -n "${2:-}" ] || die "set requires a state argument"; set_state "$2" ;;
    toggle) toggle ;;
    ""|--help|-h) usage ;;
    *) die "unknown command '$1'"; usage ;;
esac
